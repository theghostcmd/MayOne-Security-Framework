@"
# Python
__pycache__/
*.py[cod]
*.so
.Python
env/
venv/
*.egg-info/
dist/
build/

# Database files
*.db
*.sqlite
*.sqlite3

# Logs
logs/*.log
*.log

# Models
models/
*.pkl

# GeoIP database
geoip/*.mmdb

# Sensitive config
config_local.py

# IDE
.vscode/
.idea/
*.swp

# OS junk
.DS_Store
Thumbs.db

# Temporary PCAP exports
*.pcap
"@ | Out-File -FilePath .gitignore -Encoding utf8